pipeline {
    agent any
    
    environment {
            APP_NAME="Excel-2"
    }



    stages {
        stage('Checkout') {
            steps {
                echo "Clonando repo"
                checkout scm
            }
        }

        

        stage ('Lint Backend') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    echo 'Executing flake8...'
                    script {
                        sh '''
                            echo "WORKSPACE=$WORKSPACE"
                            pwd
                            ls -la

                            docker run --rm \
                            -v $WORKSPACE:/app \
                            python:3.11-slim \
                            ls -la /app
                            bash -c "pip install flake8 && flake8 /app/backend --max-line-length=120"
                        '''
                    }
                }
            }
        }


        stage ('Lint Frontend') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    echo "Executing ESLint..."
                    script {
                        sh '''
                            docker run --rm \
                            -v $WORKSPACE:/app \
                            node:20 \
                            bash -c "cd /app/frontend && npm install --silent && npm run lint"
                        '''
                    }
                }
            }
        }
        


        stage('Build Containers') {
            steps {
                sh 'docker compose -f ../docker/docker-compose.ci.yml build'
            }
        }


        stage('Test Containers') {
            steps {
                sh 'docker compose -f ../docker/docker-compose.ci.yml up -d'
                sleep 10
                sh 'curl --fail http://localhost:8081/health || exit 1'
                sh 'curl --fail http://localhost:3001 || exit 1'
            }
        }



        // examples
        stage('Lint') {
            when {
                branch 'main'
                branch pattern: "feature/.*", comparator: "REGEXP"
            }
            steps {
                echo "sh npm instal"
                echo "sh npm run lint"
                echo "El package.son debe tener: 'scripts': {'lint': 'eslint'. }"
            }
        }

        stage('Backend Tests') {
            steps {
                echo "Aqui van los tests de Python"
            }
        }

        stage('Run Test Features') {
            when {
                branch pattern: "feature/.*", comparator: "REGEXP"        
            }
            steps {
                echo 'Esto es un feature'
            }
        }

        stage('PR') {
            when { 
                changeRequest target: 'main' 
            }
            steps {
                echo "Validaciones extra para pull requests"
            }
        }
    }



    post {
        always {
            sh 'docker compose -f ../docker/docker-compose.ci.yml down -v'
            sh 'docker system prune -f'
        }
        
        success {
            echo "Pipeline completado :)"
        }
        
        failure {
            echo "Pipeline fallo :("
        }
    }
}
