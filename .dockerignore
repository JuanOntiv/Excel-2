# ============================================
# CARPETAS COMPLETAS QUE NO DEBEN IR AL CONTEXTO
# ============================================
# docker/               # Archivos de orquestación (compose, Dockerfiles auxiliares)
# ci/                   # Integración continua (Jenkins, scripts)
# tests/                # Tests (no necesarios para construir la imagen)
# # frontend/node_modules/# Evitar que se envíe si existe localmente
# backend/__pycache__/  # Caché de Python (si existe)

# ============================================
# ARCHIVOS DE ENTORNO Y SENSIBLES
# ============================================
.env                  # Variables de entorno (claves, contraseñas)
.env.local
.env.*.local
*.log
*.pid
*.seed
*.sqlite
*.db

# ============================================
# ENTORNOS VIRTUALES Y DEPENDENCIAS LOCALES
# ============================================
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/

# Node (frontend)
# node_modules/
# npm-debug.log*
# yarn-debug.log*
# yarn-error.log*

# ============================================
# EDITORES Y ARCHIVOS DEL SISTEMA
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# CONTROL DE VERSIONES
# ============================================
.git/
.gitignore
.gitattributes
.gitmodules

# ============================================
# ARCHIVOS DE TESTS Y COBERTURA
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

